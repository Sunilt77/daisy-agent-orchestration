# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENAI_API_KEY: Required for OpenAI API calls.
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# ANTHROPIC_API_KEY: Required for Anthropic API calls.
ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"
AGENTOPS_API_KEY="MY_AGENTOPS_API_KEY"

# Optional: built-in `google_search` internal tool (Google Custom Search JSON API)
# You can also provide api_key/search_engine_id per tool call.
GOOGLE_SEARCH_API_KEY="MY_GOOGLE_SEARCH_API_KEY"
GOOGLE_SEARCH_ENGINE_ID="MY_PROGRAMMABLE_SEARCH_ENGINE_ID"

# Postgres (Platform DB)
DATABASE_URL="postgresql://agentops:agentops@localhost:5432/agentops?schema=public"

# Platform Auth
# Used for hashing API keys and signing cookie values. Must be >= 32 chars in prod.
APP_SECRET="dev-only-change-me-dev-only-change-me"

# Optional: session duration in days
SESSION_DAYS="7"

# Optional: if set, internal orchestrator executions will also be written
# as runs/events into the platform database under the project owning this key.
PLATFORM_PROJECT_API_KEY="ak_..."

# Optional alternative to PLATFORM_PROJECT_API_KEY:
# You can also choose an ingestion project from the Platform UI, which is stored
# in the local SQLite `orchestrator.db` settings table.

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional Redis (recommended for Cloud Run / multi-instance)
REDIS_URL="redis://localhost:6379"

# SQLite location (Cloud Run default should be in /tmp)
SQLITE_PATH="/tmp/orchestrator/orchestrator.db"

# Optional GCS sync for SQLite state (Cloud Run)
# If set, app restores SQLite at startup and periodically syncs it back.
GCS_SQLITE_BUCKET="my-orchestrator-state-bucket"
GCS_SQLITE_PREFIX="state"
GCS_SYNC_INTERVAL_MS="30000"

# Optional helper values for importing external Meta MCP server as an MCP tool.
# Use: npm run add:meta-mcp -- --expose
META_MCP_SERVER_URL="http://localhost:3001/mcp"
META_MCP_TOOL_NAME="meta_ads_mcp_cursor"
META_MCP_EXPOSED_NAME="tool_meta_ads_mcp_cursor"

# Job queue settings
JOB_CONCURRENCY=2
JOB_TIMEOUT_MS=120000

# Default retry policy
RETRY_MAX_RETRIES=5
RETRY_BASE_DELAY_MS=2000

# Aggressive retry policy
AGGRESSIVE_RETRY_MAX_RETRIES=7
AGGRESSIVE_RETRY_BASE_DELAY_MS=500

# Relaxed retry policy
RELAXED_RETRY_MAX_RETRIES=3
RELAXED_RETRY_BASE_DELAY_MS=2500
